import QtQuick 2.15

QtObject {
    // Semi-transparent black
    property color background: "#80000000" // 50% opacity black

    // Dark orange main color
    property color primary: "#FF8C00" // Dark orange

    // Accent color (optional)
    property color accent: "#FFA040" // Slightly lighter orange

    // Text colors
    property color textPrimary: "#FFFFFF"
    property color textSecondary: "#B0B0B0"

    // Border color
    property color border: "#40FF8C00" // 25% opacity dark orange
}
